{
    "name": "digitaldreams/local-batch-api",
    "description": "Drop-in replacement for Anthropic and OpenAI batch APIs, self-hosted against Ollama or LM Studio.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "BatchApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["BatchApi\\BatchApiServiceProvider"],
            "aliases": {
                "BatchApi": "BatchApi\\Facades\\BatchApi"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
